{
  "name": "@lumen/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check src",
    "test": "pnpm run build && node --test test/*.test.mjs && node --input-type=module -e \"const db = await import('./dist/index.js'); if (!db.getMongoDatabase || !db.HomeFeaturedRepository) process.exit(1)\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws4": "^1.13.2",
    "ioredis": "^5.4.1",
    "mongodb": "^6.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "typescript": "^5.6.3"
  }
}
