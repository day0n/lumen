{
  "name": "@lumen/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deps:build": "pnpm --filter @lumen/shared build && pnpm --filter @lumen/db build",
    "predev": "pnpm run deps:build",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "pnpm run deps:build",
    "build": "tsc --noEmit && vite build && tsx scripts/prerender-landing.ts && pnpm run verify:bundle",
    "verify:bundle": "tsx test/verify-canvas-bundle.ts && tsx test/verify-landing-bundle.ts && tsx test/verify-auth-bundle.ts",
    "test": "tsx --test test/*.test.ts",
    "pretypecheck": "pnpm run deps:build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@clerk/localizations": "^4.7.0",
    "@clerk/react": "6.7.1",
    "@lumen/shared": "workspace:*",
    "@mantine/core": "^7.13.4",
    "@mantine/hooks": "^7.13.4",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@sentry/react": "10.55.0",
    "@tabler/icons-react": "^3.21.0",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/router-plugin": "^1.168.18",
    "@xyflow/react": "^12.3.5",
    "clsx": "^2.1.1",
    "jotai": "^2.10.1",
    "motion": "^11.11.9",
    "nanoid": "^5.0.7",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "three": "^0.184.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^7.2.7"
  }
}
