{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "allowJs": true,
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@/i18n/messages": ["./src/i18n/messages.ts"],
      "@/i18n/provider": ["./src/i18n/provider.tsx"],
      "@/i18n/routing": ["./src/i18n/routing.ts"],
      "@/components/home/AuroraBackdrop": ["./src/components/shell/AuroraBackdrop.tsx"],
      "@/components/home/NotificationsPopover": ["./src/components/shell/NotificationsPopover.tsx"],
      "@/components/home/Topbar": ["./src/components/shell/Topbar.tsx"],
      "@/components/i18n/LanguageToggle": ["./src/components/shell/LanguageToggle.tsx"],
      "@/components/mobile/MobileSheet": ["./src/components/shell/MobileSheet.tsx"],
      "@/components/mobile/SafeAreaContainer": ["./src/components/shell/SafeAreaContainer.tsx"],
      "@/components/ui/LumenMark": ["./src/components/shell/LumenMark.tsx"],
      "@/components/voice/VoiceInputControl": ["./src/components/voice/VoiceInputControl.tsx"],
      "@/hooks/use-is-mobile": ["./src/hooks/use-is-mobile.ts"],
      "@/hooks/use-media-query": ["./src/hooks/use-media-query.ts"],
      "@/hooks/use-speech-to-text": ["./src/hooks/use-speech-to-text.ts"],
      "@/lib/app-shell-chrome": ["./src/lib/app-shell-chrome.tsx"],
      "@/lib/auth-redirect": ["./src/lib/auth-redirect.ts"],
      "@/lib/cn": ["./src/lib/cn.ts"],
      "@/lib/protected-paths": ["./src/lib/protected-paths.ts"],
      "@/*": ["../lumen-studio/src/*"],
      "@app/*": ["./src/*"],
      "next/link": ["./src/compat/next-link.tsx"],
      "next/navigation": ["./src/compat/next-navigation.ts"],
      "@clerk/nextjs": ["./src/compat/clerk-next.ts"],
      "@sentry/nextjs": ["./src/compat/sentry-next.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../lumen-studio/src/components/**/*.ts",
    "../lumen-studio/src/components/**/*.tsx",
    "../lumen-studio/src/features/**/*.ts",
    "../lumen-studio/src/features/**/*.tsx",
    "../lumen-studio/src/hooks/**/*.ts",
    "../lumen-studio/src/hooks/**/*.tsx",
    "../lumen-studio/src/app/hot-videos/page.tsx",
    "../lumen-studio/src/i18n/**/*.ts",
    "../lumen-studio/src/i18n/**/*.tsx",
    "../lumen-studio/src/lib/**/*.ts",
    "../lumen-studio/src/lib/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "../lumen-studio/src/i18n/server.ts"]
}
