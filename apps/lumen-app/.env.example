# Public authentication key required by the browser application.
VITE_CLERK_PUBLISHABLE_KEY=

# Browser telemetry. Deployment workflows require a DSN.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1

# Leave empty to use the same-origin /v1/agent route.
NEXT_PUBLIC_AGENT_URL=
