# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ── Auth & CORS ──────────────────────────────────────────
# Clerk issuer URL (from Clerk dashboard -> JWT Templates or API Keys page)
CLERK_ISSUER=https://enabling-camel-38.clerk.accounts.dev
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ── LLM Providers ────────────────────────────────────────
# Anthropic（Claude）
ANTHROPIC_API_KEY=

# 火山方舟（豆包，OpenAI 兼容协议）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_ENDPOINT=ep-20260514115629-vhldw

# ── 默认 model ───────────────────────────────────────────
DEFAULT_MODEL=claude-opus-4-7
DEFAULT_MAX_TOKENS=8192

# ── Storage ──────────────────────────────────────────────
# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lumen_agent
STUDIO_MONGODB_DB=lumen_app
WORKFLOW_MONGODB_DB=lumen_engine

# Redis（Upstash 或自管）
REDIS_URL=redis://localhost:6379
WORKFLOW_STREAM_KEY=lumen:flow:tasks

# ── Tools ────────────────────────────────────────────────
# Web search（Brave，可选；空则 fallback DuckDuckGo）
BRAVE_API_KEY=

# Foreplay（视频搜索）
FOREPLAY_API_KEY=
FOREPLAY_BASE_URL=https://public.api.foreplay.co

# Vertex Gemini（视频/图像理解，base64 后的 GCP service account JSON）
GOOGLE_OC_JSON=
VERTEX_GEMINI_PROJECT=

# 通用 OpenAI key（gpt-4o-mini 用于 video_search 候选过滤）
OPENAI_API_KEY=

# 出站代理（可选）
HTTP_PROXY=

# ── Sentry（全链路 trace + 日志）─────────────────────────
# DSN 来自 Sentry org lumen-y0 下的 node project。留空 = 优雅禁用（no-op）。
SENTRY_DSN=
# 上报环境名，留空则用 NODE_ENV
SENTRY_ENVIRONMENT=
# trace 采样率：dev 用 1.0，prod 按量调低（如 0.1）
SENTRY_TRACES_SAMPLE_RATE=1.0
