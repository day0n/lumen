{
  "name": "@lumen/studio",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deps:build": "pnpm --filter @lumen/shared build && pnpm --filter @lumen/db build && pnpm --filter @lumen/backend build",
    "db:build": "pnpm --filter @lumen/db build",
    "predev": "pnpm run deps:build",
    "dev": "tsx watch --clear-screen=false server.ts",
    "prebuild": "pnpm run deps:build",
    "build": "next build",
    "pree2e:remake": "pnpm run db:build",
    "e2e:remake": "tsx scripts/e2e-remake-runner.ts",
    "prestart": "pnpm run deps:build",
    "start": "NODE_ENV=production tsx server.ts",
    "pretest": "pnpm run deps:build",
    "test": "tsx --test test/*.test.ts",
    "lint": "biome check .",
    "pretypecheck": "pnpm run deps:build",
    "typecheck": "tsc --noEmit",
    "preverify:remake-flow": "pnpm run db:build",
    "verify:remake-flow": "tsx scripts/verify-remake-ugc-flow.ts",
    "preseed": "pnpm run db:build",
    "seed": "tsx scripts/seed-mock.ts",
    "preseed:home-templates": "pnpm run db:build",
    "seed:home-templates": "tsx scripts/seed-home-workflow-templates.ts",
    "preseed:tiktok": "pnpm run db:build",
    "seed:tiktok": "tsx scripts/seed-tiktok.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "3.1054.0",
    "@clerk/backend": "3.4.13",
    "@clerk/localizations": "^4.7.0",
    "@clerk/nextjs": "^7.4.1",
    "@google/genai": "^2.6.0",
    "@lumen/backend": "workspace:*",
    "@lumen/db": "workspace:*",
    "@lumen/shared": "workspace:*",
    "@mantine/core": "^7.13.4",
    "@mantine/hooks": "^7.13.4",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@sentry/nextjs": "^10.55.0",
    "@tabler/icons-react": "^3.21.0",
    "@tanstack/react-query": "^5.59.16",
    "@xyflow/react": "^12.3.5",
    "clsx": "^2.1.1",
    "https-proxy-agent": "^9.0.0",
    "ioredis": "^5.4.1",
    "jotai": "^2.10.1",
    "mongodb": "^6.10.0",
    "motion": "^11.11.9",
    "nanoid": "^5.0.7",
    "next": "^15.1.0",
    "openai": "^4.73.0",
    "ogl": "^1.0.11",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.4",
    "three": "^0.184.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "overrides": {}
}
