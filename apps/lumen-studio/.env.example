# Studio server storage
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lumen_app
WORKFLOW_MONGODB_DB=lumen_engine

# Optional cache
REDIS_URL=redis://localhost:6379

# Agent service URL
LUMEN_AGENT_URL=http://localhost:3001
NEXT_PUBLIC_AGENT_URL=http://localhost:3001

# Public Studio URL used for generated links (prod: https://lumenstudio.tech)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk auth (https://dashboard.clerk.com/ -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Apify (TikTok URL → video metadata via clockworks/tiktok-scraper actor)
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxx

# Vertex Gemini（素材库 AI 卖点生成）。与 engine/agent 用同一套凭证。
# GOOGLE_OC_JSON = base64 编码的 service account JSON；缺失时 AI 卖点会提示「还没有配置」。
GOOGLE_OC_JSON=base64_encoded_service_account_json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Cloudflare R2 (object storage for hot-video covers and previews)
# https://dash.cloudflare.com -> R2 -> Manage R2 API tokens
# 必须开启 bucket 的 public access（R2.dev subdomain 或自定义域名），把
# 它对应的 https 地址填到 R2_PUBLIC_BASE_URL，例如 https://pub-xxxx.r2.dev
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# ── Sentry（全链路 trace + 日志）─────────────────────────
# 服务端 DSN（自定义 server + RSC + WS gateway）。留空 = 优雅禁用（no-op）。
SENTRY_DSN=
# 浏览器端 DSN（前端错误 + 性能 trace），可与服务端同一个 nextjs project
NEXT_PUBLIC_SENTRY_DSN=
# 上报环境名，留空则用 NODE_ENV
SENTRY_ENVIRONMENT=
# trace 采样率：dev 用 1.0，prod 按量调低（如 0.1）
SENTRY_TRACES_SAMPLE_RATE=1.0
# 上传 source map 用（CI / 部署时），本地开发可留空
SENTRY_AUTH_TOKEN=
