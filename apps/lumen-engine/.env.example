PORT=3002
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lumen_engine

# Cloudflare R2 (required for image/video/audio workflow results)
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

GOOGLE_OC_JSON=base64_encoded_service_account_json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
FISH_AUDIO_API_KEY=your_fish_audio_api_key

# KIE.AI (Suno music generation for the audio `suno-music` model)
KIE_API_KEY=your_kie_api_key
# KIE 的 /generate 强制要求 callBackUrl 字段；结果用轮询拿，不依赖回调。留空则用默认占位。
KIE_CALLBACK_URL=

# Local automatic video editing (lumen-video-edit)
VIDEO_EDIT_FFMPEG_PATH=ffmpeg
VIDEO_EDIT_FFPROBE_PATH=ffprobe
VIDEO_EDIT_MAX_CLIPS=8
VIDEO_EDIT_MAX_DURATION_SECONDS=180
VIDEO_EDIT_MAX_INPUT_MB=350

# ── Sentry（全链路 trace + 日志）─────────────────────────
# DSN 来自 Sentry org lumen-y0 下的 node project。留空 = 优雅禁用（no-op）。
SENTRY_DSN=
# 上报环境名，留空则用 NODE_ENV
SENTRY_ENVIRONMENT=
# trace 采样率：dev 用 1.0，prod 按量调低（如 0.1）
SENTRY_TRACES_SAMPLE_RATE=1.0
